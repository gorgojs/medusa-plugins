{
  "name": "@gorgo/medusa-payment-robokassa",
  "version": "0.3.9",
  "description": "Robokassa payment provider for Medusa",
  "files": [
    ".medusa/server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gorgojs/medusa-plugins",
    "directory": "packages/medusa-payment-robokassa"
  },
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-payment",
    "medusa-payment",
    "medusa-payment-robokassa",
    "robokassa-payment",
    "robokassa",
    "Робокасса"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "yarn predev && medusa plugin:develop",
    "predev": "medusa plugin:publish",
    "prepublishOnly": "medusa plugin:build",
    "test:unit": "jest --config jest.config.js"
  },
  "dependencies": {
    "@gorgo/telemetry": "^1.0.1",
    "axios": "^1.9.0",
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.14.0",
    "@medusajs/cli": "^2.14.0",
    "@medusajs/framework": "^2.14.0",
    "@medusajs/icons": "^2.14.0",
    "@medusajs/medusa": "^2.14.0",
    "@medusajs/test-utils": "^2.14.0",
    "@medusajs/ui": "^4.0.25",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "jest": "^29.7.0",
    "msw": "^2.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.14.0",
    "@medusajs/cli": "^2.14.0",
    "@medusajs/framework": "^2.14.0",
    "@medusajs/icons": "^2.14.0",
    "@medusajs/medusa": "^2.14.0",
    "@medusajs/test-utils": "^2.14.0",
    "@medusajs/ui": "^4.0.25"
  },
  "engines": {
    "node": ">=20"
  }
}
