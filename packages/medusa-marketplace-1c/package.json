{
  "name": "@gorgo/medusa-marketplace-1c",
  "version": "0.0.1",
  "description": "1C:Enterprise marketplace integration for Medusa via CommerceML 2",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2",
    "1c",
    "1С",
    "1c:enterprise",
    "1С:Предприятие",
    "commerceml",
    "marketplace",
    "medusa-marketplace"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "yarn predev && medusa plugin:develop",
    "predev": "medusa plugin:publish",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "commerceml-parser": "^3.0.3",
    "sluga": "^0.2.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@gorgo/medusa-marketplace": "*",
    "@medusajs/admin-sdk": "^2.13.3",
    "@medusajs/cli": "^2.13.3",
    "@medusajs/framework": "^2.13.3",
    "@medusajs/icons": "^2.13.3",
    "@medusajs/medusa": "^2.13.3",
    "@medusajs/test-utils": "^2.13.3",
    "@medusajs/ui": "^4.0.25",
    "@swc/core": "^1.5.7",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "@types/unzipper": "^0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@gorgo/medusa-marketplace": "*",
    "@medusajs/admin-sdk": "^2.13.3",
    "@medusajs/cli": "^2.13.3",
    "@medusajs/framework": "^2.13.3",
    "@medusajs/icons": "^2.13.3",
    "@medusajs/medusa": "^2.13.3",
    "@medusajs/test-utils": "^2.13.3",
    "@medusajs/ui": "^4.0.25"
  },
  "engines": {
    "node": ">=20"
  }
}
