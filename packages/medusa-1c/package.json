{
  "name": "@gorgo/medusa-1c",
  "version": "2.0.0-beta.1",
  "description": "Medusa plugin for integration with 1C:Enterprise",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorgojs/medusa-plugins",
    "directory": "packages/medusa-1c"
  },
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-other",
    "medusa-plugin-erp",
    "1c",
    "1С",
    "1c:enterprise",
    "1С:Предприятие",
    "1С Предприятие"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "yarn predev && medusa plugin:develop",
    "predev": "medusa plugin:publish",
    "prepublishOnly": "medusa plugin:build",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@gorgo/telemetry": "^1.0.1",
    "body-parser": "^1.20.5",
    "commerceml-parser": "^3.0.3",
    "commerceml-parser-core": "^2.1.3",
    "sluga": "^0.2.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@gorgo/medusa-integration": "workspace:*",
    "@medusajs/admin-sdk": "^2.17.2",
    "@medusajs/cli": "^2.17.2",
    "@medusajs/framework": "^2.17.2",
    "@medusajs/icons": "^2.17.2",
    "@medusajs/test-utils": "^2.17.2",
    "@medusajs/ui": "^4.0.25",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "@types/unzipper": "^0",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@gorgo/medusa-integration": "*",
    "@medusajs/admin-sdk": "^2.17.2",
    "@medusajs/cli": "^2.17.2",
    "@medusajs/framework": "^2.17.2",
    "@medusajs/icons": "^2.17.2",
    "@medusajs/test-utils": "^2.17.2",
    "@medusajs/ui": "^4.0.25"
  },
  "engines": {
    "node": ">=20"
  }
}
