{
  "name": "@gorgo/medusa-vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for Medusa",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./dist/src/*.js",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "vite"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "yarn build && yalc publish"
  },
  "peerDependencies": {
    "vite": "^5.2.11"
  },
  "dependencies": {
    "@babel/parser": "7.25.6",
    "@babel/traverse": "7.25.6",
    "@babel/types": "7.25.6",
    "chokidar": "^3.5.3",
    "fdir": "6.1.1",
    "magic-string": "0.30.5",
    "outdent": "^0.8.0",
    "picocolors": "^1.1.0"
  },
  "yalcSig": "7ac5ad0285a72fe3dde808d607fb4fb6"
}
