{
  "name": "@gorgo/telemetry",
  "version": "1.1.1",
  "description": "Telemetry for Gorgo",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorgojs/medusa-plugins",
    "directory": "packages/utils/gorgo-telemetry"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "keywords": [
    "gorgo",
    "telemetry",
    "analytics"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "yarn build && yalc publish",
    "prepare": "tsup"
  },
  "dependencies": {
    "configstore": "^5.0.1"
  },
  "devDependencies": {
    "@types/configstore": "^6.0.2",
    "@types/node": "^22.13.11",
    "tsup": "^8.5.1",
    "typescript": "^5.6.2",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
