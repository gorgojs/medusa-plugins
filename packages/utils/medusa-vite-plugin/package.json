{
  "name": "@gorgo/medusa-vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for Medusa",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./dist/src/*.js",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "vite"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "yarn build && yalc publish"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "vite": "^5.2.11"
  },
  "dependencies": {
    "@babel/parser": "7.25.6",
    "@babel/traverse": "7.25.6",
    "@babel/types": "7.25.6",
    "chokidar": "^3.5.3",
    "fdir": "6.1.1",
    "magic-string": "0.30.5",
    "outdent": "^0.8.0",
    "picocolors": "^1.1.0"
  }
}
