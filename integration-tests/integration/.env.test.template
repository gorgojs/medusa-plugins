# medusaIntegrationTestRunner builds the temporary test DB connection from these DB_* vars
# (@medusajs/test-utils getDatabaseURL), NOT from DATABASE_URL. Defaults match examples/docker-compose.yml.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
CI=true

# Required by @gorgo/medusa-integration to encrypt secret options at rest (any non-empty string).
GORGO_INTEGRATION_ENCRYPTION_KEY=test-secret   # don't change this

LOG_LEVEL=error
